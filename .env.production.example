cat > .env.production.example << 'EOF'
# ============================================
# ICERD - FRONTEND PRODUCTION TEMPLATE
# Copiez ce fichier en .env.production sur votre serveur
# ============================================

# API URL
VITE_API_URL=/api

# Backend URL
VITE_BACKEND_URL=https://votre-backend.onrender.com

# Mode de l'application
VITE_NODE_ENV=production

# Nom de l'application
VITE_APP_NAME=ICERD - Centre de Recherche

# Version de l'application
VITE_APP_VERSION=1.0.0

# Site URL
VITE_SITE_URL=https://votre-domaine.netlify.app

# Debug
VITE_DEBUG=false

# Google Analytics - Measurement ID (optionnel)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Matomo Analytics (optionnel)
VITE_MATOMO_URL=https://matomo.votre-domaine.com
VITE_MATOMO_SITE_ID=1
EOF
cat > .env.example << 'EOF'
# ============================================
# ICERD - FRONTEND ENVIRONNEMENT
# Copiez ce fichier en .env et modifiez les valeurs
# Ne JAMAIS committer le fichier .env
# ============================================

# API URL (pour les appels depuis le frontend)
# En développement, Vite proxy redirige /api vers le backend
VITE_API_URL=/api

# Backend URL (pour les requêtes directes)
# Développement : http://localhost:4000
# Production : https://icerd-backend.onrender.com
VITE_BACKEND_URL=http://localhost:4000

# Mode de l'application (development | production)
VITE_NODE_ENV=development

# Nom de l'application
VITE_APP_NAME=ICERD

# Version de l'application
VITE_APP_VERSION=1.0.0

# Site URL
VITE_SITE_URL=http://localhost:5173

# Debug (true | false)
VITE_DEBUG=false

# Google Analytics - Measurement ID (optionnel)
# Exemple: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Matomo Analytics (optionnel)
VITE_MATOMO_URL=
VITE_MATOMO_SITE_ID=
EOF
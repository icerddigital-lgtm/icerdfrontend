cd "/media/mvom/NA2 DEV/ICERD CAMEROUN /SITE ICERD/icerd-platform/frontend"

cat > .gitignore << 'EOF'
# ============================================
# ICERD - FRONTEND .gitignore
# ============================================

# Dépendances
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environnement
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Système d'exploitation
.DS_Store
Thumbs.db
desktop.ini

# Éditeurs
.vscode/
.idea/
*.swp
*.swo
*~

# Build
dist/
build/
out/
.next/
*.tsbuildinfo

# Tests
coverage/
.nyc_output/

# Fichiers temporaires
tmp/
temp/
*.tmp
*.temp

# Fichiers de configuration utilisateur
.vscode/
.idea/
*.iml

# Fichiers volumineux
*.mp4
*.avi
*.mov
*.mkv
*.mp3
*.wav
*.zip
*.rar
*.7z
*.tar
*.gz

# Exception pour les templates d'environnement
!.env.example
!.env.production.example
EOF